{
  "name": "Sudoku Solver Container",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // One extension per language this repo actually contains:
  // - vscjava.vscode-java-pack: Java + Maven support for SudokuServer
  //   (redhat.java, Maven for Java, Debugger for Java, Test Runner for Java)
  // - redhat.vscode-xml: XML support, e.g. SudokuServer/pom.xml
  // - ocamllabs.ocaml-platform: OCaml Platform (Merlin-based) for
  //   sudoku_solver_inez/src. This repo builds with omake + a pinned,
  //   camlp4-based Jane Street Core (112.35.01) rather than dune/modern
  //   ocaml-lsp-server, so full IntelliSense may not come up cleanly --
  //   syntax highlighting and basic editing support still work.
  // - dsznajder.es7-react-js-snippets: React/JSX snippets for
  //   sudoku_ui_prj/sudoku-ui-src (JS/JSX language support itself is
  //   already built into VS Code).
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.vscode-xml",
        "ocamllabs.ocaml-platform",
        "dsznajder.es7-react-js-snippets"
      ]
    }
  },

  // Deliberately NOT declaring forwardPorts/portsAttributes for 3000/8080
  // here. Both frontend (Vite) and backend (SudokuServer) run as *sibling*
  // containers via `docker compose up` (see the docker.sock mount below),
  // not nested inside this devcontainer -- Compose already publishes both
  // ports straight to the host (`docker-compose.yml`'s `ports:`), so
  // `localhost:3000`/`:8080` work with no forwarding at all. A prior version
  // of this file declared them in forwardPorts anyway, purely to get them
  // auto-labeled in VS Code's Ports panel -- but VS Code's own forwarding
  // for a declared port sets up a *second*, independent local listener on
  // the same port. If that listener outlives the container instance it was
  // pointed at (e.g. this devcontainer gets recreated, as happens on a
  // config change), it's left bound and stale while Docker's own listener
  // on the same port keeps working -- and since both bind to `localhost` on
  // the same port, whichever one the OS/browser happens to route a given
  // connection to is arbitrary, so requests would intermittently hang
  // against the dead VS Code tunnel instead of reaching Docker's live one.
  // Losing the auto-detected Ports panel entry is a worthwhile trade to
  // avoid the *automatic* trigger for that bug class -- it doesn't remove
  // VS Code's manual "Forward a Port" action from the Ports panel, though,
  // so don't manually forward 3000/8080 there either: doing so recreates
  // the identical stale-listener risk by hand.

  // The image is built as user "dev" ($HOME=/home/dev), and opam's env
  // (eval `opam config env`, used by sudoku_solver_inez/src/solver.sh) is
  // only set up under /home/dev/.opam. Attaching as root would have no
  // opam switch at all, so run_solver.sh needs this to be dev.
  "remoteUser": "dev",

  // Bind-mount the live repo directly over the path the image was built at
  // ($HOME/app) instead of the default /workspaces/<name>, so live edits to
  // e.g. sudoku_solver_inez/src land exactly where solver.sh's relative
  // paths (../../libs/inez, ../../libs/scipoptsuite-3.1.1) expect them.
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/dev/app,type=bind,consistency=cached",
  "workspaceFolder": "/home/dev/app",

  // docker-compose.yml's bind-mount volume sources (./sudoku_solver_inez,
  // ./sudoku_ui_prj/sudoku-ui-src) are plain relative paths, resolved by the
  // Compose CLI against its own working directory. That's fine for a
  // regular host checkout, but "docker compose up" run from *this*
  // devcontainer's terminal talks to the real host's Docker daemon over the
  // bind-mounted docker.sock (see the "mounts" entry below) while running
  // inside this container's own filesystem -- so the relative path resolves
  // to /home/dev/app/sudoku_solver_inez, a path that only exists inside
  // this devcontainer, not on the actual Docker host. The real daemon then
  // refuses it ("not shared from the host"). HOST_REPO_ROOT gives Compose
  // the real host-side path to prefix those sources with instead, taking
  // over from the ".": ${localWorkspaceFolder} is exactly the path
  // workspaceMount above bind-mounted this repo from on the real host.
  "containerEnv": {
    "HOST_REPO_ROOT": "${localWorkspaceFolder}"
  },

  // libs/inez and libs/scipoptsuite-3.1.1 contain compiled build output
  // (inez.top/inez.opt, libscipopt.so) produced while building the image,
  // not present in the plain host source tree. Mount these two paths as
  // named volumes -- Docker seeds a new empty volume from the image's
  // content at that path on first use -- so the bind mount above doesn't
  // shadow the compiled output with the (unbuilt) host copy. (There's no
  // longer a node_modules volume here -- the frontend's node_modules live
  // inside its own sibling container/image now, not in this one.)
  //
  // If you change libs/inez or libs/scipoptsuite-3.1.1 and rebuild the
  // image, delete these two volumes so they get reseeded from the new build
  // (otherwise the old compiled output persists in the volume).
  //
  // Also bind-mount the host's own docker.sock, giving this container's
  // docker CLI (see Dockerfile) a route to the host's Docker daemon so
  // `docker compose up frontend` runs the frontend as a sibling container.
  "mounts": [
    "source=sudoku-solver-inez-libs-inez,target=/home/dev/app/libs/inez,type=volume",
    "source=sudoku-solver-inez-libs-scip,target=/home/dev/app/libs/scipoptsuite-3.1.1,type=volume",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  // Three independent things need to happen on every container start:
  // - sudoku_solver_inez/src's own OMakefile builds a "sudoku" OCaml library
  //   (sudoku.cma) that solver.init loads at runtime. That compiled output
  //   is baked into the image but lives inside the plain bind-mounted
  //   workspace (unlike libs/inez and libs/scipoptsuite-3.1.1 above), so it
  //   gets shadowed by the host source on mount. Rebuild it (fast, ~1s,
  //   incremental) so run_solver.sh has an up-to-date sudoku.cma.
  // - The mounted docker.sock above is root-owned, group "root", mode 660
  //   (group-writable, no other access) by default, and dev (a non-root
  //   remoteUser) isn't in that group, so it can't reach the daemon
  //   through it as-is. Two earlier versions of this fix were both wrong:
  //   adding dev to the socket's *existing* group (its GID varies by
  //   host/Docker install, resolved and joined via groupadd/usermod at
  //   container-start time) doesn't work because supplementary group
  //   membership is fixed for a process at fork/exec time and only
  //   re-read from /etc/group on a fresh login -- any VS Code terminal
  //   forked from the vscode-server process that was already running
  //   before that step completed (a real race on every container start,
  //   not a one-off) stayed stuck with the daemon permanently denied for
  //   that whole VS Code session, even after the step visibly succeeded.
  //   `chmod 666`-ing the socket avoided that race (file-mode checks are
  //   re-evaluated by the kernel on every syscall, so they can't go stale
  //   per-process the same way) but overshot: docker.sock is a
  //   `type=bind` mount, so chmod-ing it inside the container mutates the
  //   *real* host-side (or Docker Desktop VM) socket file's permission
  //   bits, leaving it world-read/write to every process on the host/VM,
  //   not just dev -- a much bigger exposure than intended, and one that
  //   outlives the devcontainer itself. The fix here instead chowns the
  //   socket's *group* to dev -- not a supplementary group dev has to
  //   be added to at runtime, but dev's own primary group (fixed at
  //   image-build time via `useradd`, gid 1000), so every process running
  //   as dev already carries it from exec with no login-session
  //   dependency at all, and mode stays at its default 660 so only root
  //   and dev can reach it, not the whole host. Needs root, hence the
  //   scoped sudoers rule in Dockerfile. (Same caveat applies to this
  //   approach as the old one, though: if the host's Docker
  //   daemon/socket is ever recreated independently of this devcontainer
  //   -- e.g. a host-side daemon restart -- the new socket file reverts
  //   to root:root and this chown needs to run again, which happens
  //   automatically on the *next* devcontainer start, same self-heal
  //   pattern as /vscode below, but not mid-session.)
  // - /vscode (VS Code Dev Containers' own shared, cross-project server
  //   cache volume) gets its VS Code Server tarball extracted as root on
  //   first use of any given commit, mode 755 -- unwritable by remoteUser
  //   dev. VS Code's own runtime self-patch step (see
  //   VSCODE_SERVER_CUSTOM_GLIBC_LINKER etc. in Dockerfile) needs to rewrite
  //   its `node` binary in place as dev to point it at /opt/vscode-glibc,
  //   which silently fails ("Permission denied", swallowed by VS Code's own
  //   script) without this. Loosen it back up on every start so a fresh VS
  //   Code Server version self-heals on the next start after its first
  //   (failed) connection attempt, rather than staying broken forever.
  "postStartCommand": {
    "rebuild-solver": "bash -lc 'eval `opam config env` && cd ${containerWorkspaceFolder}/sudoku_solver_inez/src && omake'",
    "docker-socket-perms": "sudo chown root:dev /var/run/docker.sock",
    "fix-vscode-server-perms": "sudo chmod -R a+rwX /vscode"
  }
}
